# ── LLM Provider Configuration ─────────────────────────────────────────────
# Set the active provider (default: anthropic)
# CD_AGENCY_PROVIDER=anthropic

# Provider API keys — set the key for your active provider
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx
# GEMINI_API_KEY=AIxxxxx
# OPENROUTER_API_KEY=sk-or-xxxxx
# KIMI_API_KEY=sk-xxxxx

# Optional: Override the default model for the active provider
# CD_AGENCY_MODEL=claude-sonnet-4-20250514

# Optional: Custom base URL (for proxies, Azure, self-hosted endpoints)
# CD_AGENCY_BASE_URL=https://your-proxy.example.com/v1

# Optional: Path to agent definitions directory
# CD_AGENCY_AGENTS_DIR=./content-design
